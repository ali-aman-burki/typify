def eval(expression: Any, globals: Any = ..., locals: Any = ...) -> Any: ...
def exec(object: Any, globals: Any = ..., locals: Any = ...) -> None: ...
def compile(source: Any, filename: Any, mode: Any, flags: Any = ..., dont_inherit: Any = ..., optimize: Any = ...) -> Any: ...
def format(value: Any, format_spec: Any = ...) -> str: ...
def hash(obj: Any) -> int: ...
def help(obj: Any = ...) -> None: ...
def ord(c: str) -> int: ...
def chr(i: int) -> str: ...
def bin(x: Any) -> str: ...
def oct(x: Any) -> str: ...
def hex(x: Any) -> str: ...
def sorted(iterable: Any, *, key: Any = ..., reverse: bool = ...) -> list[Any]: ...
def reversed(seq: Any) -> Any: ...
def enumerate(iterable: Any, start: int = ...) -> Any: ...
def zip(*iterables: Any) -> Any: ...
def map(func: Any, *iterables: Any) -> Any: ...
